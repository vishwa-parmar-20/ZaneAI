.git/
.gitignore
.gitattributes

# Documentation
README.md
*.md

# Logs
*.log
logs/

# Runtime data
pids/
*.pid
*.seed

# Coverage directory used by tools like istanbul
coverage/

# Dependency directories (already copied via requirements.txt)
node_modules/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Docker files (to avoid recursive copying)
Dockerfile*
docker-compose*.yml
.dockerignore

# Test files
tests/
test/
*.test.py
pytest.ini
.pytest_cache/

# Virtual environments
.venv/
venv/
ENV/
env/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Database files
*.db
*.sqlite
*.sqlite3

# Temporary files
tmp/
temp/
.tmp/

# Build artifacts
build/
dist/
*.egg-info/

# Environment files (will be managed by Docker Compose)
# .env

# Local development files
local/
dev/